@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct:  <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix chess: <{{.ChessNS}}> .

<{{.BaseURL}}/catalog>
    a dcat:Catalog ;
    rdfs:label "{{.NodeName}}" ;
    dct:description "Federated knowledge fabric node." ;
    dct:publisher <{{.IRIBase}}> ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:conformsTo <https://w3id.org/cogitarelink/fabric#CoreProfile> ;
    dcat:service <{{.BaseURL}}/sparql> ;
    dcat:landingPage <{{.BaseURL}}> ;

    dcat:catalog
    {{- range $i, $b := .Beamlines }}
        {{- if $i}},{{ end }}
        <{{$.BaseURL}}/catalog/{{$b.ID}}>
    {{- end }} ;

    dct:modified "{{.ModifiedDate}}"^^xsd:date .

{{/* ---- Beamline entries ---- */}}

{{- range .Beamlines }}

<{{$.BaseURL}}/catalog/{{.ID}}>
    a dcat:Catalog , chess:Beamline ;
    rdfs:label "{{.Label}}" ;
    dct:description "{{.Description}}" ;
    dcat:service <{{$.BaseURL}}/sparql> ;
    chess:beamlineType "{{.Type}}" ;
    chess:location "{{.Location}}"
    {{- if .Alias }} ;
    chess:alias "{{.Alias}}"
    {{- end }}
    {{- if .Partners }} ;
    chess:partner
        {{- range $i, $p := .Partners }}
            {{- if $i}},{{ end }}
            "{{$p}}"
        {{- end }}
    {{- end }} .

{{- end }}
