{
  "@context": {
    "void":  "http://rdfs.org/ns/void#",
    "dcat":  "http://www.w3.org/ns/dcat#",
    "dct":   "http://purl.org/dc/terms/",
    "rdfs":  "http://www.w3.org/2000/01/rdf-schema#",
    "chess": "http://chess.cornell.edu/ns#"
  },
  "@id": "{{.BaseURL}}/catalog",
  "@type": "dcat:Catalog",
  "rdfs:label": "{{.NodeName}}",

  "dct:description": "CHESS Federated Knowledge Fabric Node",
  "dct:conformsTo": {
    "@id": "https://w3id.org/cogitarelink/fabric#CoreProfile"
  },

  "dcat:service": {
    "@id": "{{.BaseURL}}/sparql",
    "@type": "dcat:DataService"
  },

  "dcat:catalog": [
    {
      "@id": "{{.BaseURL}}/catalog/beamline-id1",
      "@type": "dcat:Catalog",
      "rdfs:label": "Beamline ID1 — X-ray Diffraction",
      "chess:beamlineType": "x-ray-diffraction"
    },
    {
      "@id": "{{.BaseURL}}/catalog/beamline-id3",
      "@type": "dcat:Catalog",
      "rdfs:label": "Beamline ID3 — Protein Crystallography",
      "chess:beamlineType": "protein-crystallography"
    },
    {
      "@id": "{{.BaseURL}}/catalog/beamline-fast",
      "@type": "dcat:Catalog",
      "rdfs:label": "Beamline FAST — Time-Resolved Scattering",
      "chess:beamlineType": "time-resolved-scattering"
    }
  ]
}